# =============================================================================
# Hybrid Environment — Cloud Databases + Local Workers
# =============================================================================
# Copy to .env.hybrid:  cp .env.hybrid.example .env.hybrid
# Fill in your Neon and Upstash credentials below.
# ⚠️ Never commit .env.hybrid to Git.
# =============================================================================

# =============================================================================
# NEON POSTGRESQL (cloud)
# Get these from: neon.tech → your project → Connection Details
# =============================================================================
# Set SQLALCHEMY_DATABASE_URI directly to override per-component assembly.
# Neon requires SSL — the ?ssl=require at the end is mandatory.
# Format: postgresql+asyncpg://user:password@host/dbname?ssl=require
SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://YOUR_USER:YOUR_PASSWORD@ep-xxx-xxx.us-east-1.aws.neon.tech/neondb?ssl=require

# Also set individual components (used by event-engine and reid-service
# which assemble their own connection string)
POSTGRES_SERVER=ep-xxx-xxx.us-east-1.aws.neon.tech
POSTGRES_USER=YOUR_NEON_USER
POSTGRES_PASSWORD=YOUR_NEON_PASSWORD
POSTGRES_DB=neondb
POSTGRES_PORT=5432

# =============================================================================
# UPSTASH REDIS (cloud)
# Get from: upstash.com → your database → Details → Redis URL
# ⚠️ Upstash uses rediss:// (with SSL) — not redis://
# =============================================================================
REDIS_URI=rediss://default:YOUR_UPSTASH_PASSWORD@YOUR_ENDPOINT.upstash.io:6379

# =============================================================================
# EDGE NODE — Camera Configuration
# =============================================================================
STORE_ID=a1b2c3d4-0001-4000-8000-000000000001

# Path to your local video files on the HOST machine (left of colon)
# Inside the container it maps to /videos (right of colon)
VIDEO_SOURCE_DIR=./CCTV sources

# Camera list — cam_id:/videos/filename.mp4
CAMERA_LIST=cam-1:/videos/CAM 1.mp4,cam-2:/videos/CAM 2.mp4,cam-3:/videos/CAM 3.mp4,cam-4:/videos/CAM 4.mp4,cam-5:/videos/CAM 5.mp4

# =============================================================================
# SHARED SETTINGS
# =============================================================================
ENVIRONMENT=production
LOG_LEVEL=INFO
