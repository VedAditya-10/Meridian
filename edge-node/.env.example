# Edge Node Environment Configuration
# =================================

# Redis Connection for Event Streaming
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Model Configuration
YOLO_MODEL=yolov8n.pt
CONFIDENCE_THRESHOLD=0.5

# Performance Tuning
FPS_TARGET=2
BATCH_SIZE=1

# Hardware (cpu / cuda / mps)
DEVICE=cpu
