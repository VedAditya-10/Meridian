# Meridian Backend API Environment Configuration
# =============================================

# Server Configuration
ENVIRONMENT=development
PORT=8000

# Single-store fixed UUID (must match edge-node STORE_ID)
MERIDIAN_STORE_ID=a1b2c3d4-0001-4000-8000-000000000001
MAX_CAMERAS=6

# Database Connections
SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:postgres@localhost:5432/store_intelligence
REDIS_URI=redis://localhost:6379/0

# CORS Origins (JSON array string)
BACKEND_CORS_ORIGINS=["http://localhost:5173", "https://your-vercel-domain.vercel.app"]
