# =============================================================================
# Store Intelligence — ReID Service Environment
# =============================================================================
# Copy to `.env`:  cp .env.example .env
# ⚠️  Never commit the actual `.env` file.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL — ReID Service reads visitor embeddings and resolves identities
# using pgvector cosine similarity. Requires the pgvector extension to be
# enabled on the database (handled automatically by backend-api on startup).
# When running via docker-compose: POSTGRES_SERVER=postgres
# For local dev outside Docker: POSTGRES_SERVER=localhost
# -----------------------------------------------------------------------------
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=store_intelligence

# -----------------------------------------------------------------------------
# Redis Streams
# Reads from: telemetry_raw  (raw detections from edge nodes)
# Writes to:  telemetry_resolved  (identity-resolved telemetry for event engine)
# When running via docker-compose: redis://redis:6379/0
# For local dev outside Docker: redis://localhost:6379/0
# -----------------------------------------------------------------------------
REDIS_URI=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# ReID Matching Thresholds (optional tuning)
# Cosine similarity threshold for identity matching (0.0–1.0).
# Lower = stricter matching, fewer false-positives.
# Default: 0.75
# -----------------------------------------------------------------------------
# REID_SIMILARITY_THRESHOLD=0.75

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
