# =============================================================================
# Store Intelligence — Frontend Dashboard Environment
# =============================================================================
# Copy to `.env`:  cp .env.example .env
# ⚠️  Never commit the actual `.env` file.
#
# Vite only exposes environment variables prefixed with VITE_ to the browser.
# All variables here are embedded into the JavaScript bundle at build time.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend API URL
# The base URL of the backend-api service — consumed by all fetch() calls.
#
# Local development (Docker Compose):
#   VITE_API_BASE_URL=http://localhost:8000/api/v1
#
# Production (Railway backend deployed):
#   VITE_API_BASE_URL=https://your-backend.railway.app/api/v1
#
# ⚠️ No trailing slash.
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1
