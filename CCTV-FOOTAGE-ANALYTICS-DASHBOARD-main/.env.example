# =============================================================================
# Meridian — Root Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# This file is used by docker-compose.yml at the repository root.
# Each individual service also has its own .env.example for standalone use.
#
# ⚠️  NEVER commit your actual `.env` file to Git.
# =============================================================================

# =============================================================================
# POSTGRESQL (pgvector/pgvector:pg16)
# =============================================================================
# Credentials for the Postgres container AND all services that connect to it.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=store_intelligence
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432

# =============================================================================
# REDIS
# =============================================================================
# Internal Redis URI — uses the Docker service name as the host.
REDIS_URI=redis://redis:6379/0

# =============================================================================
# BACKEND API
# =============================================================================
# Comma-separated list of allowed CORS origins (the frontend URL).
# In production, replace with your actual frontend domain.
BACKEND_CORS_ORIGINS=http://localhost:5173

# Application runtime environment: development | staging | production
ENVIRONMENT=development

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# =============================================================================
# FRONTEND DASHBOARD
# =============================================================================
# The public URL of the backend API — consumed by the React build at compile time.
# In production, set this to your Railway/Render/Fly.io backend URL.
# Example: https://store-intel-api.railway.app/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# =============================================================================
# EDGE NODE
# =============================================================================
# Fixed single-store UUID (backend MERIDIAN_STORE_ID + edge-node STORE_ID).
MERIDIAN_STORE_ID=a1b2c3d4-0001-4000-8000-000000000001
STORE_ID=a1b2c3d4-0001-4000-8000-000000000001
MAX_CAMERAS=6

# Camera list: comma-separated pairs of cam_id:/path/to/video
# Video files must be mounted into the container — see docker-compose.yml volumes.
# Example for 5 cameras:
CAMERA_LIST=cam-1:/videos/CAM 1.mp4,cam-2:/videos/CAM 2.mp4,cam-3:/videos/CAM 3.mp4,cam-4:/videos/CAM 4.mp4,cam-5:/videos/CAM 5.mp4
