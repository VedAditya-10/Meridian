# =============================================================================
# Store Intelligence Platform — Combined .gitignore
# Covers: Python | Node.js | Docker | VSCode | OS artifacts | Project-specific
# =============================================================================

# =============================================================================
# SECURITY — NEVER COMMIT THESE
# =============================================================================
# Real environment files (templates named .env.example ARE committed)
.env
.env.local
.env.*.local
.env.production
.env.staging
.env.development
.env.hybrid

# =============================================================================
# PROJECT-SPECIFIC — LARGE/SENSITIVE FILES
# =============================================================================

# CCTV video footage — 680 MB+ of real footage, NOT for public repos
# Users must provide their own video files or RTSP streams
CCTV sources/
*.mp4
*.avi
*.mkv
*.mov
*.wmv
*.flv
*.webm

# ML model weights — auto-downloaded by ultralytics/torch on first run
*.pt
*.pth
*.onnx
*.weights
yolov8*.pt
yolov8*.yaml
runs/

# =============================================================================
# PYTHON
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env/
venv/
ENV/
env.bak/
venv.bak/
.venv/
env/

# Test and coverage artifacts
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover
.hypothesis/
pytestdebug.log
nosetests.xml
test-results/

# Jupyter Notebooks
.ipynb_checkpoints

# pyenv
.python-version

# Celery
celerybeat-schedule
celerybeat.pid

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre
.pyre/

# Pyright / Pylance
pyrightconfig.json

# Ruff cache
.ruff_cache/

# =============================================================================
# NODE.JS / FRONTEND
# =============================================================================

# Dependencies
node_modules/
jspm_packages/
bower_components/

# Build outputs
dist/
dist-ssr/
build/
out/
.output/
.nuxt/
.next/
.svelte-kit/

# Vite cache
.vite/

# TypeScript
*.tsbuildinfo

# npm / yarn / pnpm lockfile alternatives (keep package-lock.json or yarn.lock)
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Coverage reports
coverage/
lcov.info
*.lcov

# Storybook
storybook-static/

# =============================================================================
# DOCKER
# =============================================================================

# Docker override files for local dev (keep docker-compose.yml, ignore local overrides)
docker-compose.override.yml
docker-compose.local.yml

# =============================================================================
# LOGS
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
pip-log.txt
pip-delete-this-directory.txt

# =============================================================================
# OPERATING SYSTEM
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# =============================================================================
# IDE / EDITORS
# =============================================================================

# VSCode (keep .vscode/extensions.json if desired, ignore everything else)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains (PyCharm, WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
Netrw*

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# =============================================================================
# ALEMBIC — keep migrations, ignore generated artifacts
# =============================================================================
# (Migration files in alembic/versions/ SHOULD be committed)

# =============================================================================
# TEMPORARY / SCRATCH
# =============================================================================
tmp/
temp/
scratch/
*.tmp
*.bak
*.swp
*.swo
